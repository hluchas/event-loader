{
  "name": "hluchas/event-loader",
  "description": "Distributed event loading core",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "psr/clock": "^1.0",
    "psr/log": "^3.0",
    "symfony/console": "^6.4"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "phpstan/phpstan": "^1.11",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "stan": "phpstan analyse",
    "test": "phpunit",
    "all": "php-cs-fixer fix && phpstan analyse && phpunit"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": false
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
